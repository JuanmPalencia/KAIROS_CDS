# ═══════════════════════════════════════════════
# KAIROS CDS — Backend Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and adjust values as needed

# ── Database ──
DATABASE_URL=postgresql+psycopg2://twin:twin@localhost:55432/twin

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── JWT Authentication ──
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── OpenAI (optional — enables AI chat, vision, severity classification) ──
OPENAI_API_KEY=

# ── BSV Blockchain (optional — enables audit notarization) ──
# Generate wallet: python -c "from bsv import PrivateKey; k=PrivateKey(); print(k.wif())"
BSV_PRIVATE_KEY=
BSV_NETWORK=main
ARC_URL=https://arc.gorillapool.io

# ── Twin Engine ──
TICK_MS=500

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── Security ──
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_BRUTE_FORCE_ENABLED=true
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_MINUTES=10
